# ============================================================
# 君君 AGENT 环境变量配置模板
# 复制为 .env 后填写真实值
# ============================================================

# -------------------- 君君主程序 --------------------
MAIBOT_QQ_ACCOUNT=
MAIBOT_NICKNAME=君君

# 网关 WS 端口（NapCat ws client 连接此端口）
JUNJUN_GATEWAY_HOST=127.0.0.1
JUNJUN_GATEWAY_PORT=8092

# -------------------- WebUI --------------------
WEBUI_ENABLED=false
WEBUI_HOST=127.0.0.1
WEBUI_PORT=8002
WEBUI_MODE=production

# -------------------- API Keys --------------------
DEEPSEEK_API_KEY=
SILICONFLOW_API_KEY=
BAILIAN_API_KEY=
GOOGLE_API_KEY=

# -------------------- Langfuse（自托管） --------------------
# docker compose -f langfuse/docker-compose.yml up -d  →  http://localhost:3000
LANGFUSE_ENABLED=false
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-xxx
LANGFUSE_SECRET_KEY=sk-lf-xxx

# -------------------- 语音（可选） --------------------
DOUBAO_TTS_API_KEY=
