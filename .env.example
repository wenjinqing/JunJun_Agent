# ============================================================
# 君君 AGENT 环境变量配置模板
# 复制为 .env 后填写真实值
# ============================================================

# -------------------- 君君主程序 --------------------
MAIBOT_QQ_ACCOUNT=
MAIBOT_NICKNAME=君君

# 网关 WS 端口（NapCat ws client 连接此端口）
JUNJUN_GATEWAY_HOST=127.0.0.1
JUNJUN_GATEWAY_PORT=8092

# -------------------- 安全（管理员 + 通道鉴权） --------------------
# 最高权限管理员 QQ：可远程指挥 bot（私聊/群里指令必达），敏感操作仅此号可用。
# 机制硬编码在 junjun_core/security.py，配置/WebUI/聊天内容都改不了权限。
ADMIN_QQ=
# 网关 <-> Adapter 通道鉴权令牌（随机生成一串，如 python -c "import secrets;print(secrets.token_hex(24))"）。
# 必须与 junjun_adapter_napcat/config.toml 的 [maibot_server] token 完全一致。
# 不配置则网关仅接受本机回环连接；[gateway] host 配成对外地址时未配置会拒绝启动。
GATEWAY_TOKEN=
# NapCat 连入 Adapter 的 accessToken（对应 NapCat 侧配置；空=不校验，仅本机使用建议留空）
NAPCAT_TOKEN=

# -------------------- WebUI --------------------
WEBUI_ENABLED=false
WEBUI_HOST=127.0.0.1
WEBUI_PORT=8002
WEBUI_MODE=production
WEBUI_TOKEN=

# -------------------- API Keys --------------------
DEEPSEEK_API_KEY=
SILICONFLOW_API_KEY=
BAILIAN_API_KEY=
GOOGLE_API_KEY=

# -------------------- 任务模型（config/model_config.toml 的默认 env 组） --------------------
# 所有任务槽默认共用这一组；想让 gate/agent 用不同模型，
# 在 model_config.toml 里把对应槽的 *_env 指向下面任一组自定义变量即可
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_API_KEY=

# 可选：自定义分组示例（取消注释并在 model_config.toml 引用）
# GATE_LLM_BASE_URL=https://api.deepseek.com/v1
# GATE_LLM_MODEL=deepseek-chat
# GATE_LLM_API_KEY=
# AGENT_LLM_BASE_URL=https://api.siliconflow.cn/v1
# AGENT_LLM_MODEL=Qwen/Qwen2.5-72B-Instruct
# AGENT_LLM_API_KEY=

# 可选：多模态识图（task.vlm 槽）。不配置则识图降级为 [图片] 占位
# VLM_BASE_URL=https://api.siliconflow.cn/v1
# VLM_MODEL=Qwen/Qwen2.5-VL-72B-Instruct
# VLM_API_KEY=

# -------------------- Langfuse（自托管） --------------------
# docker compose -f langfuse/docker-compose.yml up -d  →  http://localhost:3000
LANGFUSE_ENABLED=false
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-xxx
LANGFUSE_SECRET_KEY=sk-lf-xxx

# -------------------- 语音（可选） --------------------
DOUBAO_TTS_API_KEY=
# 多后端 TTS（插件 tts）：默认后端与各后端地址/音色（均有默认值）
# TTS_DEFAULT_BACKEND=doubao
# TTS_GSV2P_URL=https://gsv2p.acgnai.top
# TTS_GSV2P_TOKEN=
# TTS_SOVITS_URL=http://127.0.0.1:9880
# TTS_SOVITS_REF_AUDIO=
# TTS_SOVITS_PROMPT_TEXT=

# -------------------- 插件（均有默认值，按需配置） --------------------
# NapCat OneBot HTTP API（wife 群成员/发文件/maizone 取 cookie 需要；在 NapCat 开 httpServers）
# NAPCAT_HTTP_BASE=http://127.0.0.1:3000
# NAPCAT_HTTP_TOKEN=            # httpServer 的 token（注意与上面 NAPCAT_TOKEN 区分：那个是 WS 连入鉴权）
# AI 画图（ModelScope 文生图）
# MODELSCOPE_API_KEY=
# AI_DRAW_MODEL=Tongyi-MAI/Z-Image-Turbo
# AI_DRAW_MODEL_ANIME=
# B 站视频解析（cookie 提画质/过风控；ffmpeg 需在 PATH 才能发视频，否则降级信息卡）
# BILI_SESSDATA=
# BILI_MAX_DURATION=600
# BILI_MAX_SIZE_MB=100
# 网盘直链（本机 netdisk-fast-download 服务地址）
# NETDISK_API_BASE=http://127.0.0.1:6400
# 定时话题联网热点（topic_finder 的 web_llm_enable=true 时必需）
# TOPIC_WEB_LLM_API_KEY=
